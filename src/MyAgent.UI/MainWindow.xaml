<Window x:Class="MyAgent.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MyAgent - 混合双打自律系统" Height="800" Width="1200"
        Icon="pack://application:,,,/Resources/app-icon.ico"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 左侧交互与配置区 -->
            <ColumnDefinition Width="460" MinWidth="350" />
            <ColumnDefinition Width="5" />
            
            <!-- 右侧浏览器预览区 -->
            <ColumnDefinition Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>

        <!-- 左侧配置与日志面板 -->
        <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="0,0,1,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <StackPanel Orientation="Horizontal" Background="#2C3E50" Margin="0,0,0,10">
                        <TextBlock Text="🧩 已加载自动化工作流节点" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="10,0,10,0"/>
                        <Button Content="🔄 重载字典" Command="{Binding LoadSkillsCommand}" Margin="5" Padding="10,2"/>
                        <Button Content="🛠️ 技能管理大仓" Click="OpenSkillManager_Click" Margin="5" Padding="10,2" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="运行时参数控制台" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="⚙️ 全局设置" Command="{Binding OpenSettingsCommand}" Padding="10,5" Cursor="Hand" />
                    </Grid>
                    
                    <TextBlock Text="执行技能模板选择" FontWeight="Bold" FontSize="14" Margin="0,0,0,5" Foreground="Gray" />
                    <ComboBox ItemsSource="{Binding Skills}" 
                              SelectedItem="{Binding SelectedSkill, Mode=TwoWay}"
                              DisplayMemberPath="Name" 
                              Margin="0,0,0,10" Height="28" />

                    <TextBlock Text="当前技能动态参数注入" FontWeight="Bold" FontSize="14" Margin="0,10,0,10" Foreground="Gray" />
                    
                    <!-- 显示当前使用的 AI 模型 -->
                    <Border Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1" CornerRadius="3" Padding="8,5" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🤖 当前使用模型：" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedAiProfile.Name, FallbackValue='未选择'}" 
                                       FontWeight="Bold" 
                                       Foreground="#1B5E20" 
                                       Margin="5,0,0,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" | " Foreground="#BDBDBD" Margin="5,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AiModelName, FallbackValue='N/A'}" 
                                       Foreground="#424242" 
                                       FontStyle="Italic"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- 动态参数绑定示例：目标 URL 与 Prompt -->
                    <TextBlock Text="初始加载网址(若有):" />
                    <TextBox Text="{Binding ParamTargetUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" />
                    
                    <TextBlock Text="AI Prompt / Goal:" />
                    <TextBox Text="{Binding ParamPrompt, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" Margin="0,5,0,5" TextWrapping="Wrap" />

                    <CheckBox Content="开启诊断报告/运行结果 Webhook 推送" IsChecked="{Binding EnableWebhookPush}" Margin="0,10,0,10" FontWeight="Bold" Foreground="#0275d8" />

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" 
                                Content="执行技能 (Execute)" 
                                Command="{Binding ExecuteSkillCommand}" 
                                Background="#4CAF50" 
                                Foreground="White" 
                                FontWeight="Bold" 
                                Height="40"
                                Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        
                        <Button Grid.Column="0" 
                                Content="⏸️ 取消执行" 
                                Command="{Binding CancelExecutionCommand}" 
                                Background="#F44336" 
                                Foreground="White" 
                                FontWeight="Bold" 
                                Height="40"
                                Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </StackPanel>

                <GroupBox Grid.Row="1" Header="执行日志" Margin="0,10,0,0">
                    <TextBox Text="{Binding ExecutionLogText, Mode=OneWay}" 
                             IsReadOnly="True" 
                             TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" 
                             BorderThickness="0"
                             Background="Transparent" />
                </GroupBox>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#E0E0E0" ShowsPreview="True" />

        <!-- 右侧浏览器预览面板 -->
        <Border Grid.Column="2" Padding="10">
            <TabControl SelectedIndex="{Binding RightTabIndex}">
                <TabItem Header="🌐 浏览器进程实况">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,5,0,10" LastChildFill="False">
                            <TextBlock Text="无头浏览器 DOM 与行为轨迹监控窗" FontWeight="Bold" Foreground="Gray" VerticalAlignment="Center" />
                            <CheckBox Content="🌙 暗色" IsChecked="{Binding UseDarkWebMode, Mode=TwoWay}" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1">
                            <wv2:WebView2 x:Name="MainWebView" DefaultBackgroundColor="White" />
                        </Border>
                        <StatusBar Grid.Row="2" Background="#F0F0F0" Margin="0,5,0,0" Padding="5,2">
                            <StatusBarItem>
                                <TextBlock Text="{Binding BrowserStatusText}" FontWeight="SemiBold" Foreground="#333" />
                            </StatusBarItem>
                        </StatusBar>
                    </Grid>
                </TabItem>
                <TabItem Header="📄 AI 智能报告洞察">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,5,0,10" LastChildFill="False">
                            <TextBlock Text="技能归纳与结构化富文本结晶" FontWeight="Bold" Foreground="Gray" VerticalAlignment="Center" />
                            <CheckBox Content="🌙 暗色" IsChecked="{Binding UseDarkWebMode, Mode=TwoWay}" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1">
                            <wv2:WebView2 x:Name="MarkdownReportWebView" DefaultBackgroundColor="#FAFAFA" />
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="🖥️ 云端 VPS 终端">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="云端自动化部署与执行台 (不会泄露凭证给 AI 引擎)" FontWeight="Bold" Margin="0,5,0,10" Foreground="#0275d8" />
                        
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="服务器 IP:" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBox Grid.Column="1" Text="{Binding ParamVpsHost, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" />
                            
                            <TextBlock Grid.Column="2" Text="端口:" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBox Grid.Column="3" Text="{Binding ParamVpsPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" />
                            
                            <TextBlock Grid.Column="4" Text="账户:" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBox Grid.Column="5" Text="{Binding ParamVpsUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" />
                            
                            <TextBlock Grid.Column="6" Text="密码:" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <PasswordBox Grid.Column="7" x:Name="VpsPasswordBox" PasswordChanged="VpsPasswordBox_PasswordChanged" Margin="0,0,10,0"/>

                            <Button Grid.Column="8" Content="🔗 连接探针" Command="{Binding TestVpsConnectionCommand}" Padding="10,2" Cursor="Hand" Background="#0275d8" Foreground="White" FontWeight="Bold"/>
                        </Grid>

                        <Border Grid.Row="2" BorderBrush="#2C3E50" BorderThickness="1.5" Background="Black">
                            <wv2:WebView2 x:Name="VpsTerminalWebView" Margin="0" />
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>

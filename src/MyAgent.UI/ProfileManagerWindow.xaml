<Window x:Class="MyAgent.UI.ProfileManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 模型库大管家 (AI Profile Manager)" Height="550" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="配置您拥有的专属模型服务网关与通信密钥" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="网关预设列表">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <ListBox Grid.Row="0" ItemsSource="{Binding AiProfiles}" 
                             SelectedItem="{Binding SelectedEditableProfile, Mode=TwoWay}"
                             DisplayMemberPath="Name" Margin="5"/>
                             
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,5">
                        <Button Content="➕ 新建" Width="80" Command="{Binding CreateNewProfileCommand}" Margin="0,0,10,0"/>
                        <Button Content="🗑️ 删除" Width="80" Command="{Binding DeleteProfileCommand}" Foreground="Red" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="详细参数与探针配置">
                <StackPanel Margin="10" IsEnabled="{Binding IsProfileSelected}">
                    <TextBlock Text="配置方案名称:" />
                    <TextBox Text="{Binding SelectedEditableProfile.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" />

                    <TextBlock Text="Base Url (OpenAI 兼容端点):" />
                    <TextBox Text="{Binding SelectedEditableProfile.BaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>

                    <TextBlock Text="Model Name (如 qwen-plus):" />
                    <TextBox Text="{Binding SelectedEditableProfile.ModelName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>

                    <TextBlock Text="API Key (凭证令牌):" />
                    <TextBox Text="{Binding SelectedEditableProfile.ApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>

                    <Border Background="#F9F9F9" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="模型可用性探针校对系统" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333333" />
                            <TextBlock Text="系统将向外发射简短的打招呼 Payload 作为网络防火墙渗透测试..." TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10" />
                            
                            <Button Content="🧪 发起连通性测试 (Test Connection)" Command="{Binding TestConnectionCommand}" Height="35" Background="#E3F2FD" FontWeight="Bold" />
                            <TextBlock Text="{Binding ConnectionTestResult}" Margin="0,10,0,0" FontWeight="Bold" Foreground="{Binding ConnectionTestColor}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="完成并存盘" Command="{Binding SaveProfilesCommand}" Width="120" Height="30" Background="#4CAF50" Foreground="White" FontWeight="Bold" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="MyAgent.UI.SkillManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YAML 技能编排库管理中心 (Skill Manager)" Height="600" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="管理项目内所有的 YAML 自动化技能节点" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="物理技能文件清单">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0" ItemsSource="{Binding SkillFiles}" 
                             SelectedItem="{Binding SelectedFile, Mode=TwoWay}" Margin="5"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,5">
                        <Button Content="➕ 新技能" Width="70" Command="{Binding CreateNewSkillCommand}" Margin="0,0,10,0"/>
                        <Button Content="🗑️ 删除" Width="70" Command="{Binding DeleteSkillCommand}" Foreground="Red" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="YAML 源码编排编辑器 (带格式探伤与强力阻断)">
                <Grid Margin="10" IsEnabled="{Binding IsSkillSelected}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <TextBox Grid.Row="0" Text="{Binding SelectedFilePath, Mode=OneWay}" IsReadOnly="True" Background="#EEEEEE" Margin="0,0,0,10"/>

                    <TextBox Grid.Row="1" Text="{Binding EditorContent, UpdateSourceTrigger=PropertyChanged}" 
                             AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                             FontFamily="Consolas" FontSize="14"
                             HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Grid.Row="2" Text="{Binding ValidationError}" Foreground="Red" TextWrapping="Wrap" Margin="0,10,0,0" FontWeight="Bold"/>
                </Grid>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="💾 保存并热加载" Command="{Binding SaveSkillCommand}" Width="150" Height="30" Background="#4CAF50" Foreground="White" FontWeight="Bold" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
